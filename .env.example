# Copy to `.env` and fill in. `.env` is git-ignored — never commit real keys.
# See docs/architecture.md §"データソース登録手順" for how to obtain each.

# --- USPTO Open Data Portal (data.uspto.gov) ---
# Free, instant. Covers US full text (claims/description), prosecution, continuity.
# Get a key: https://data.uspto.gov/apis/getting-started
USPTO_ODP_API_KEY=

# --- EPO Open Patent Services (OPS) v3.2 ---
# Free, OAuth2. Covers EP full text + worldwide bibliographic / INPADOC family /
# legal status + JP English abstracts (PAJ). Fair-use quota: ~4GB/week.
# Register: https://developers.epo.org/  (creates a Consumer Key + Secret)
EPO_OPS_KEY=
EPO_OPS_SECRET=

# --- (optional, later) Google Cloud project for Patents Public Data on BigQuery ---
# Only needed if/when we add JP/global full-text via BigQuery. Free tier: 1TB query/mo.
GCP_PROJECT_ID=

# ===========================================================================
# LLM "brain" for the semantic scoring channel (OPTIONAL — keyless works without)
# Plugs into the Judge protocol (analyze/llm_judge.py). Requires: pip install -r requirements-llm.txt
# P-NO-GUESS is enforced in code: any non-verbatim evidence quote is discarded.
# Pick ONE provider. CLI: scripts/*.py --llm {azure|github|auto}
# ===========================================================================

# --- Option A: Azure OpenAI ---  (scripts/*.py --llm azure)
AZURE_OPENAI_ENDPOINT=          # e.g. https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=        # your chat model deployment name (passed as model=)
AZURE_OPENAI_API_VERSION=2024-10-21   # match what your resource supports

# --- Option B: GitHub Models (GitHub / Copilot token) ---  (scripts/*.py --llm github)
# OpenAI-compatible. Auth = a GitHub fine-grained PAT with the "models:read"
# permission (github.com → Settings → Developer settings → Fine-grained tokens).
# In GitHub Actions you can instead grant the workflow `permissions: models: read`
# and the built-in GITHUB_TOKEN is picked up automatically.
GITHUB_MODELS_TOKEN=            # your GitHub PAT (models:read). Falls back to GITHUB_TOKEN if unset.
GITHUB_MODELS_MODEL=openai/gpt-4o-mini       # publisher-prefixed model id
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
