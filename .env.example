# Copy to `.env` and fill in. `.env` is git-ignored вЂ” never commit real keys.
# See docs/architecture.md В§"гѓ‡гѓјг‚їг‚Ѕгѓјг‚№з™»йЊІж‰‹й †" for how to obtain each.

# --- USPTO Open Data Portal (data.uspto.gov) ---
# Free, instant. Covers US full text (claims/description), prosecution, continuity.
# Get a key: https://data.uspto.gov/apis/getting-started
USPTO_ODP_API_KEY=

# --- EPO Open Patent Services (OPS) v3.2 ---
# Free, OAuth2. Covers EP full text + worldwide bibliographic / INPADOC family /
# legal status + JP English abstracts (PAJ). Fair-use quota: ~4GB/week.
# Register: https://developers.epo.org/  (creates a Consumer Key + Secret)
EPO_OPS_KEY=
EPO_OPS_SECRET=

# --- (optional, later) Google Cloud project for Patents Public Data on BigQuery ---
# Only needed if/when we add JP/global full-text via BigQuery. Free tier: 1TB query/mo.
GCP_PROJECT_ID=
